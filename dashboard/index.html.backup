        // Validation Functions
        let validationStats = {
            valid: 0,
            invalid: 0,
            total: 0
        };

        // Store all validation results for export
        let allValidationResults = [];

        // Enhanced phone number validation - STRICT PAKISTANI MOBILE
        function validateNumber(number) {
            // Remove any whitespace
            const cleanNumber = number.trim();

            // STRICT VALIDATION RULES:
            // 1. Must be exactly 11 digits
            // 2. Must start with 03
            // 3. Pattern: 03XXXXXXXXX (03 followed by 9 digits)

            // Strict Pakistani Mobile Pattern: ^03[0-9]{9}$
            const strictPattern = /^03[0-9]{9}$/;

            return strictPattern.test(cleanNumber);
        }

        function startValidation() {
            const fileInput = document.getElementById('numbersFile');
            if (!fileInput.files.length) {
                alert('Please upload a CSV file first');
                return;
            }

            // Reset counters
            validationStats = { valid: 0, invalid: 0, total: 0 };
            allValidationResults = []; // Clear previous results
            updateValidationCounters();

            // Show validation summary
            document.getElementById('validationSummary').style.display = 'block';
            // Hide export buttons until validation completes
            document.getElementById('exportValidationButtons').style.display = 'none';

            const file = fileInput.files[0];
            const reader = new FileReader();

            reader.onload = function(e) {
                const text = e.target.result;
                const lines = text.split('\n').filter(line => line.trim());

                if (lines.length === 0) {
                    alert('No data found in CSV file');
                    return;
                }

                // Parse CSV and extract only phone numbers (first column)
                const numbers = [];
                for (let i = 1; i < lines.length; i++) { // Skip header row
                    const line = lines[i].trim();
                    if (!line) continue;

                    // Split by comma and take first column only (phone number)
                    const columns = line.split(',');
                    const phoneNumber = columns[0].trim();

                    // Remove any quotes that might be in the CSV
                    const cleanNumber = phoneNumber.replace(/['"]/g, '');

                    if (cleanNumber) {
                        numbers.push(cleanNumber);
                    }
                }

                if (numbers.length === 0) {
                    alert('No phone numbers found in CSV file');
                    return;
                }

                // Clear results table
                const tbody = document.getElementById('validationResults');
                tbody.innerHTML = '';

                // Simulate validation with progress
                let currentIndex = 0;
                const totalNumbers = numbers.length;

                const interval = setInterval(() => {
                    if (currentIndex >= totalNumbers) {
                        clearInterval(interval);
                        // Show export buttons after validation completes
                        document.getElementById('exportValidationButtons').style.display = 'block';
                        // Refresh dashboard stats after validation completes
                        fetchStats();
                        return;
                    }

                    // Process 5 numbers at a time for faster validation
                    const batchSize = Math.min(5, totalNumbers - currentIndex);

                    for (let i = 0; i < batchSize; i++) {
                        const number = numbers[currentIndex + i];

                        // Use enhanced validation function
                        const isValid = validateNumber(number);

                        if (isValid) {
                            validationStats.valid++;
                        } else {
                            validationStats.invalid++;
                        }
                        validationStats.total++;

                        // Store result for export
                        allValidationResults.push({
                            number: number,
                            status: isValid ? 'Valid' : 'Invalid',
                            timestamp: new Date().toLocaleString()
                        });

                        // Add to results table (only show first 50 for performance)
                        if (validationStats.total <= 50) {
                            const row = document.createElement('tr');
                            row.innerHTML = `
                                <td>${number}</td>
                                <td><span class="${isValid ? 'status-valid' : 'status-invalid'}">${isValid ? 'Valid' : 'Invalid'}</span></td>
                                <td>${new Date().toLocaleString()}</td>
                            `;
                            tbody.appendChild(row);
                        }
                    }

                    currentIndex += batchSize;

                    // Update progress
                    const progress = Math.round((currentIndex / totalNumbers) * 100);
                    document.getElementById('validationProgress').textContent = progress + '%';
                    document.getElementById('validationBar').style.width = progress + '%';

                    // Update counters in real-time
                    updateValidationCounters();

                }, 100); // Process every 100ms
            };

            reader.onerror = function() {
                alert('Error reading file');
            };

            reader.readAsText(file);
        }

        // Smart Export Function
        function exportFilteredResults(type) {
            if (allValidationResults.length === 0) {
                alert('No validation results available. Please validate numbers first.');
                return;
            }

            let filteredResults = [];
            let filename = '';

            // Filter based on type
            if (type === 'valid') {
                filteredResults = allValidationResults.filter(r => r.status === 'Valid');
                filename = `valid_numbers_${Date.now()}.csv`;
            } else if (type === 'invalid') {
                filteredResults = allValidationResults.filter(r => r.status === 'Invalid');
                filename = `invalid_numbers_${Date.now()}.csv`;
            } else if (type === 'both') {
                filteredResults = allValidationResults;
                filename = `all_numbers_${Date.now()}.csv`;
            }

            if (filteredResults.length === 0) {
                alert(`No ${type} numbers found to export.`);
                return;
            }

            // Create CSV content
            let csvContent = 'Number,Status,Timestamp\n';
            filteredResults.forEach(result => {
                csvContent += `${result.number},${result.status},"${result.timestamp}"\n`;
            });

            // Create blob and download
            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            const url = URL.createObjectURL(blob);

            link.setAttribute('href', url);
            link.setAttribute('download', filename);
            link.style.visibility = 'hidden';

            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);

            // Show success notification
            const count = filteredResults.length;
            const typeLabel = type === 'both' ? 'all' : type;
            showNotification(`Successfully exported ${count} ${typeLabel} numbers!`, 'success');
        }

        function updateValidationCounters() {
            // Ensure all values are non-negative
            const valid = Math.max(0, validationStats.valid);
            const invalid = Math.max(0, validationStats.invalid);
            const total = Math.max(0, validationStats.total);

            // Update validator page counters
            document.getElementById('validCount').textContent = valid;
            document.getElementById('invalidCount').textContent = invalid;
            document.getElementById('totalCount').textContent = total;

            // Update summary display
            document.getElementById('summaryValid').textContent = valid;
            document.getElementById('summaryInvalid').textContent = invalid;

            // Update dashboard overview counter directly (no animation during validation)
            const dashboardElement = document.getElementById('validNumbers');
            if (dashboardElement) {
                dashboardElement.textContent = total;
            }

            console.log(`Validation counters updated: Valid=${valid}, Invalid=${invalid}, Total=${total}`);
        }

        // BUG FIX 2: Bulk Sender Button Functions
        function createAndLaunchCampaign() {
            const nameInput = document.getElementById('campaignName');
            const messageInput = document.getElementById('campaignMessage');
            const fileInput = document.getElementById('campaignFile');

            const name = nameInput.value.trim();
            const message = messageInput.value.trim();

            if (!name) {
                alert('Please enter a campaign name');
                return;
            }

            if (!message) {
                alert('Please enter a message template');
                return;
            }

            if (!fileInput.files.length) {
                alert('Please upload a CSV file with contacts');
                return;
            }

            // BUG FIX 1: Add campaign to array
            const newCampaign = {
                id: 'campaign-' + Date.now(),
                name: name,
                status: 'Active',
                created: new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }),
                sent: 0,
                failed: 0,
                pending: 100 // Placeholder
            };

            campaigns.push(newCampaign);

            // Clear inputs
            nameInput.value = '';
            messageInput.value = '';
            fileInput.value = '';

            // Re-render campaigns table
            renderCampaigns();

            showNotification('Campaign created and launched successfully!', 'success');
            console.log('Campaign launched:', newCampaign);
        }

        function saveAsDraft() {
            const nameInput = document.getElementById('campaignName');
            const messageInput = document.getElementById('campaignMessage');

            const name = nameInput.value.trim();
            const message = messageInput.value.trim();

            if (!name) {
                alert('Please enter a campaign name');
                return;
            }

            if (!message) {
                alert('Please enter a message template');
                return;
            }

            // BUG FIX 1: Add campaign to array as Draft
            const newCampaign = {
                id: 'campaign-' + Date.now(),
                name: name,
                status: 'Draft',
                created: new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }),
                sent: 0,
                failed: 0,
                pending: 0
            };

            campaigns.push(newCampaign);

            // Clear inputs
            nameInput.value = '';
            messageInput.value = '';

            // Re-render campaigns table
            renderCampaigns();

            showNotification('Campaign saved as draft successfully!', 'success');
            console.log('Campaign saved as draft:', newCampaign);
        }

        // BUG FIX 1: Render campaigns table
        function renderCampaigns() {
            const tbody = document.querySelector('#bulk-sender .table-container tbody');

            if (campaigns.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 32px;">
                            <i class="fas fa-inbox" style="font-size: 48px; opacity: 0.3; display: block; margin-bottom: 16px;"></i>
                            <div style="color: var(--text-secondary);">No campaigns yet. Create your first campaign above.</div>
                        </td>
                    </tr>
                `;
                return;
            }

            tbody.innerHTML = campaigns.map(campaign => {
                const statusBadgeClass = campaign.status === 'Active' ? 'badge-success' :
                                        campaign.status === 'Paused' ? 'badge-warning' :
                                        'badge-info';

                const actionButtons = campaign.status === 'Active' ? `
                    <button class="btn btn-warning" style="padding: 6px 12px; font-size: 12px;" data-tooltip="Pause Campaign" onclick="pauseCampaignById('${campaign.id}')">
                        <i class="fas fa-pause"></i>
                    </button>
                    <button class="btn btn-danger" style="padding: 6px 12px; font-size: 12px;" data-tooltip="Stop Campaign" onclick="stopCampaignById('${campaign.id}')">
                        <i class="fas fa-stop"></i>
                    </button>
                ` : campaign.status === 'Paused' ? `
                    <button class="btn btn-success" style="padding: 6px 12px; font-size: 12px;" data-tooltip="Resume Campaign" onclick="resumeCampaignById('${campaign.id}')">
                        <i class="fas fa-play"></i>
                    </button>
                    <button class="btn btn-primary" style="padding: 6px 12px; font-size: 12px;" data-tooltip="View Details">
                        <i class="fas fa-eye"></i>
                    </button>
                ` : `
                    <button class="btn btn-success" style="padding: 6px 12px; font-size: 12px;" data-tooltip="Start Campaign" onclick="startCampaignById('${campaign.id}')">
                        <i class="fas fa-play"></i>
                    </button>
                `;

                return `
                    <tr id="${campaign.id}">
                        <td>
                            <strong>${campaign.name}</strong>
                            <div style="font-size: 11px; color: var(--text-secondary);">Created: ${campaign.created}</div>
                        </td>
                        <td><span class="badge ${statusBadgeClass}">${campaign.status}</span></td>
                        <td><strong style="color: var(--success);">${campaign.sent}</strong></td>
                        <td><strong style="color: var(--danger);">${campaign.failed}</strong></td>
                        <td><strong style="color: var(--warning);">${campaign.pending}</strong></td>
                        <td>
                            <div style="display: flex; gap: 4px;">
                                ${actionButtons}
                                <button class="btn btn-danger" style="padding: 6px 12px; font-size: 12px;" data-tooltip="Delete Campaign" onclick="deleteCampaignById('${campaign.id}')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function pauseCampaignById(id) {
            const campaign = campaigns.find(c => c.id === id);
            if (campaign) {
                campaign.status = 'Paused';
                renderCampaigns();
                showNotification(`Campaign "${campaign.name}" paused successfully!`, 'success');
            }
        }

        function resumeCampaignById(id) {
            const campaign = campaigns.find(c => c.id === id);
            if (campaign) {
                campaign.status = 'Active';
                renderCampaigns();
                showNotification(`Campaign "${campaign.name}" resumed successfully!`, 'success');
            }
        }

        function startCampaignById(id) {
            const campaign = campaigns.find(c => c.id === id);
            if (campaign) {
                campaign.status = 'Active';
                renderCampaigns();
                showNotification(`Campaign "${campaign.name}" started successfully!`, 'success');
            }
        }

        function stopCampaignById(id) {
            const campaign = campaigns.find(c => c.id === id);
            if (campaign && confirm(`Are you sure you want to stop "${campaign.name}"?`)) {
                campaign.status = 'Paused';
                renderCampaigns();
                showNotification(`Campaign "${campaign.name}" stopped successfully!`, 'success');
            }
        }

        function deleteCampaignById(id) {
            const campaign = campaigns.find(c => c.id === id);
            if (campaign && confirm(`Are you sure you want to delete "${campaign.name}"? This cannot be undone.`)) {
                campaigns = campaigns.filter(c => c.id !== id);
                renderCampaigns();
                showNotification(`Campaign "${campaign.name}" deleted successfully!`, 'success');
            }
        }

        // ===== ADVANCED GROUP EXTRACTOR - SMART FILTERING =====
        let groupExtractionMemory = {};
        let lastExtractionResult = null;

        // Load extraction memory from localStorage
        function loadExtractionMemory() {
            try {
                const stored = localStorage.getItem('groupExtractionMemory');
                if (stored) {
                    groupExtractionMemory = JSON.parse(stored);
                }
            } catch (error) {
                console.error('Error loading extraction memory:', error);
                groupExtractionMemory = {};
            }
        }

        // Save extraction memory to localStorage
        function saveExtractionMemory() {
            try {
                localStorage.setItem('groupExtractionMemory', JSON.stringify(groupExtractionMemory));
            } catch (error) {
                console.error('Error saving extraction memory:', error);
            }
        }

        function extractContacts() {
            const groupInput = document.getElementById('groupLink');
            const groupId = groupInput.value.trim();

            if (!groupId) {
                alert('Please enter a Group Link or ID');
                return;
            }

            showNotification('Extracting contacts from group... This may take a moment.', 'info');

            // Simulate extraction with realistic data
            setTimeout(() => {
                // Generate mock contacts (in real implementation, this would call WhatsApp API)
                const totalMembers = 500;
                const allContacts = [];

                for (let i = 1; i <= totalMembers; i++) {
                    allContacts.push({
                        name: `Contact ${i}`,
                        phone: `+92300${String(i).padStart(7, '0')}`,
                        status: 'Active',
                        extractionDate: new Date().toISOString()
                    });
                }

                // Initialize memory for this group if not exists
                if (!groupExtractionMemory[groupId]) {
                    groupExtractionMemory[groupId] = {
                        extractedPhones: [],
                        lastExtraction: null,
                        totalExtracted: 0
                    };
                }

                const memory = groupExtractionMemory[groupId];
                const previouslyExtracted = memory.extractedPhones.length;

                // Filter out previously extracted contacts
                const newContacts = allContacts.filter(contact =>
                    !memory.extractedPhones.includes(contact.phone)
                );

                // Limit to batch size (e.g., 234 contacts per extraction)
                const batchSize = 234;
                const contactsToExtract = newContacts.slice(0, batchSize);

                if (contactsToExtract.length === 0) {
                    showNotification('0 new contacts found. All members have been previously extracted.', 'info');
                    updateExtractionUI(groupId, totalMembers, previouslyExtracted, 0);
                    return;
                }

                // Update memory with newly extracted contacts
                contactsToExtract.forEach(contact => {
                    memory.extractedPhones.push(contact.phone);
                });
                memory.lastExtraction = new Date().toISOString();
                memory.totalExtracted = memory.extractedPhones.length;

                // Save to localStorage
                saveExtractionMemory();

                // Store result for export
                lastExtractionResult = {
                    groupId: groupId,
                    contacts: contactsToExtract,
                    stats: {
                        total: totalMembers,
                        previouslyExtracted: previouslyExtracted,
                        newFound: contactsToExtract.length,
                        remaining: totalMembers - memory.totalExtracted
                    }
                };

                // Update UI
                updateExtractionUI(groupId, totalMembers, previouslyExtracted, contactsToExtract.length);

                // Update dashboard overview with new validated numbers
                validationStats.total += contactsToExtract.length;
                updateValidationCounters();

                showNotification(`Successfully extracted ${contactsToExtract.length} new contacts!`, 'success');

                // Show export buttons
                document.getElementById('exportButtons').style.display = 'flex';

            }, 2000);
        }

        function updateExtractionUI(groupId, total, previouslyExtracted, newFound) {
            const infoDiv = document.getElementById('extractionInfo');
            const remaining = total - (previouslyExtracted + newFound);

            infoDiv.innerHTML = `
                <i class="fas fa-info-circle"></i>
                <strong>Extraction Complete:</strong><br>
                Total Members: ${total} |
                Previously Extracted: ${previouslyExtracted} |
                New Contacts Found: <strong style="color: var(--success);">${newFound}</strong> |
                Remaining: ${remaining}
            `;
        }

        // Export to CSV
        function exportToCSV() {
            if (!lastExtractionResult) {
                alert('No extraction data available. Please extract contacts first.');
                return;
            }

            const contacts = lastExtractionResult.contacts;
            const groupId = lastExtractionResult.groupId;

            // Create CSV content
            let csvContent = 'Name,Phone Number,Status,Extraction Date\n';

            contacts.forEach(contact => {
                const date = new Date(contact.extractionDate).toLocaleString();
                csvContent += `"${contact.name}","${contact.phone}","${contact.status}","${date}"\n`;
            });

            // Create blob and download
            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            const url = URL.createObjectURL(blob);

            link.setAttribute('href', url);
            link.setAttribute('download', `group_${groupId}_contacts_${Date.now()}.csv`);
            link.style.visibility = 'hidden';

            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);

            showNotification('CSV file downloaded successfully!', 'success');
        }

        // Export to Excel
        function exportToExcel() {
            if (!lastExtractionResult) {
                alert('No extraction data available. Please extract contacts first.');
                return;
            }

            // Check if SheetJS library is available
            if (typeof XLSX === 'undefined') {
                alert('Excel export library not loaded. Please refresh the page and try again.');
                console.error('SheetJS (XLSX) library not found. Add the SheetJS library to the page head.');
                return;
            }

            const contacts = lastExtractionResult.contacts;
            const groupId = lastExtractionResult.groupId;

            // Prepare data for Excel
            const excelData = contacts.map(contact => ({
                'Name': contact.name,
                'Phone Number': contact.phone,
                'Status': contact.status,
                'Extraction Date': new Date(contact.extractionDate).toLocaleString()
            }));

            // Create workbook and worksheet
            const wb = XLSX.utils.book_new();
            const ws = XLSX.utils.json_to_sheet(excelData);

            // Add worksheet to workbook
            XLSX.utils.book_append_sheet(wb, ws, 'Contacts');

            // Generate Excel file and download
            XLSX.writeFile(wb, `group_${groupId}_contacts_${Date.now()}.xlsx`);

            showNotification('Excel file downloaded successfully!', 'success');
        }

        // Clear extraction memory for a specific group
        function clearGroupMemory() {
            const groupInput = document.getElementById('groupLink');
            const groupId = groupInput.value.trim();

            if (!groupId) {
                alert('Please enter a Group Link or ID');
                return;
            }

            if (confirm(`Are you sure you want to clear extraction history for this group?\n\nThis will allow you to re-extract all contacts from the beginning.`)) {
                delete groupExtractionMemory[groupId];
                saveExtractionMemory();
                document.getElementById('extractionInfo').innerHTML = '<i class="fas fa-info-circle"></i> Extraction history cleared for this group.';
                document.getElementById('exportButtons').style.display = 'none';
                showNotification('Extraction history cleared successfully!', 'success');
            }
        }

