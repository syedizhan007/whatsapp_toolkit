        // ===== DEALS TRACKER FUNCTIONS =====
        function addDealToTracker(deal) {
            const dealsContainer = document.getElementById('dealsContainer');
            if (!dealsContainer) return;

            // Remove "no deals" message if present
            const noDeals = dealsContainer.querySelector('[data-no-deals]');
            if (noDeals) noDeals.remove();

            const phone = deal.contact.replace('@c.us', '');
            const time = new Date(deal.timestamp).toLocaleTimeString('en-US', { hour12: false });

            const dealCard = document.createElement('div');
            dealCard.className = 'glass-card';
            dealCard.style.animation = 'slideIn 0.3s ease';
            dealCard.innerHTML = `
                <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 12px;">
                    <div>
                        <div style="font-weight: 600; color: var(--primary);">${phone}</div>
                        <div style="font-size: 12px; color: var(--text-secondary);">${time}</div>
                    </div>
                    <span class="status-badge" style="background: rgba(16, 185, 129, 0.2); color: var(--success);">
                        <i class="fas fa-circle"></i> New
                    </span>
                </div>
                <div style="color: var(--text-secondary); font-size: 14px; margin-bottom: 12px;">
                    ${deal.message}
                </div>
                <div style="display: flex; gap: 8px;">
                    <button class="btn btn-success" style="flex: 1; padding: 8px;">
                        <i class="fas fa-check"></i> Complete
                    </button>
                    <button class="btn btn-danger" style="flex: 1; padding: 8px;">
                        <i class="fas fa-times"></i> Dismiss
                    </button>
                </div>
            `;

            dealsContainer.insertBefore(dealCard, dealsContainer.firstChild);
        }

        async function loadDeals() {
            try {
                const response = await fetch('/api/deals');
                const data = await response.json();

                const dealsContainer = document.getElementById('dealsContainer');
                if (!dealsContainer) return;

                if (data.deals && data.deals.length > 0) {
                    dealsContainer.innerHTML = '';
                    data.deals.forEach(deal => addDealToTracker(deal));
                } else {
                    dealsContainer.innerHTML = `
                        <div data-no-deals style="text-align: center; padding: 40px; color: var(--text-secondary);">
                            <i class="fas fa-handshake" style="font-size: 48px; opacity: 0.3; margin-bottom: 16px;"></i>
                            <div>No deals detected yet</div>
                            <div style="font-size: 12px; margin-top: 8px;">AI will automatically detect potential deals from conversations</div>
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Failed to load deals:', error);
            }
        }

        // ===== AI AGENT FUNCTIONS =====
        function updateAIAgentStatus(enabled) {
            const statusBadge = document.getElementById('aiAgentStatus');
            const statusDot = document.getElementById('aiAgentStatusDot');
            const statusText = document.getElementById('aiAgentStatusText');

            if (statusBadge) {
                statusBadge.className = enabled ? 'status-badge connected' : 'status-badge disconnected';
            }
            if (statusDot) {
                statusDot.className = enabled ? 'status-dot online' : 'status-dot offline';
            }
            if (statusText) {
                statusText.textContent = enabled ? 'Active' : 'Inactive';
            }
        }

        async function fetchAIAgentStatus() {
            try {
                const response = await fetch('/api/ai-agent/status');
                const data = await response.json();
                updateAIAgentStatus(data.enabled);
            } catch (error) {
                console.error('Failed to fetch AI agent status:', error);
            }
        }

        async function startAIAgent() {
            try {
                const response = await fetch('/api/ai-agent/toggle', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ enabled: true })
                });

                const data = await response.json();
                if (data.success) {
                    updateAIAgentStatus(true);
                    showNotification('AI Agent started successfully!', 'success');
                } else {
                    showNotification('Failed to start AI Agent', 'error');
                }
            } catch (error) {
                console.error('Failed to start AI Agent:', error);
                showNotification('Failed to start AI Agent', 'error');
            }
        }

        async function stopAIAgent() {
            try {
                const response = await fetch('/api/ai-agent/toggle', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ enabled: false })
                });

                const data = await response.json();
                if (data.success) {
                    updateAIAgentStatus(false);
                    showNotification('AI Agent stopped successfully!', 'success');
                } else {
                    showNotification('Failed to stop AI Agent', 'error');
                }
            } catch (error) {
                console.error('Failed to stop AI Agent:', error);
                showNotification('Failed to stop AI Agent', 'error');
            }
        }

        function restartAIAgent() {
            showNotification('Restarting AI Agent...', 'info');
            stopAIAgent().then(() => {
                setTimeout(() => startAIAgent(), 1000);
            });
        }

        // Wrapper functions for HTML onclick handlers
        function startAgent() {
            startAIAgent();
        }

        function stopAgent() {
            stopAIAgent();
        }

        function restartAgent() {
            restartAIAgent();
        }

        function refreshDeals() {
            showNotification('Refreshing deals...', 'info');
            loadDeals();
        }

        // ===== BULK SEND FUNCTIONS =====
        function updateBulkSendProgress(data) {
            const progressText = document.querySelector('.batch-number');
            const progressBar = document.querySelector('.progress-fill');

            if (progressText) {
                progressText.textContent = `${data.sent}/${data.total}`;
            }

            if (progressBar) {
                const percent = (data.sent / data.total) * 100;
                progressBar.style.width = `${percent}%`;
            }

            if (data.error) {
                showNotification(`Error sending to ${data.current}: ${data.error}`, 'error');
            }
        }

        // Animate stats on load
        function animateValue(id, start, end, duration) {
            const obj = document.getElementById(id);
            if (!obj) return;

            // Ensure values are non-negative
            start = Math.max(0, start);
            end = Math.max(0, end);

            // If start equals end, just set it
            if (start === end) {
                obj.textContent = end;
                return;
            }

            const range = Math.abs(end - start);
            if (range === 0) {
                obj.textContent = end;
                return;
            }

            const increment = end > start ? 1 : -1;
            const stepTime = Math.max(1, Math.floor(duration / range));
            let current = start;

            const timer = setInterval(() => {
                current += increment;

                // Safety check: never display negative numbers
                const displayValue = Math.max(0, current);
                obj.textContent = displayValue;

                if (current === end) {
                    clearInterval(timer);
                    // Final safety check
                    obj.textContent = Math.max(0, end);
                }
            }, stepTime);
        }

        // Initialize on page load
        window.addEventListener('DOMContentLoaded', () => {
            initCharts();

            // Initialize validator counters to 0
            document.getElementById('validCount').textContent = '0';
            document.getElementById('invalidCount').textContent = '0';
            document.getElementById('totalCount').textContent = '0';
            document.getElementById('validNumbers').textContent = '0';

            // Load extraction memory from localStorage
            loadExtractionMemory();

            // ===== LOAD REAL DATA =====
            fetchStats();
            loadDeals();
            loadMessageHistory();
            fetchAIAgentStatus();

            // Initialize blacklist display
            renderBlacklist();

            // Initialize campaigns display
            renderCampaigns();

            // Auto-refresh real data every 10 seconds
            setInterval(() => {
                fetchStats();
                loadDeals();
            }, 10000);

            // Add entrance animations
            document.querySelectorAll('.stat-card').forEach((card, index) => {
                card.style.animationDelay = (index * 0.1) + 's';
                card.classList.add('animate-in');
            });

            // Initialize 3D Tilt Effect on cards
            const tiltCards = document.querySelectorAll('.tilt-card');
            if (typeof VanillaTilt !== 'undefined') {
                VanillaTilt.init(tiltCards, {
                    max: 5,
                    speed: 400,
                    glare: true,
                    'max-glare': 0.2,
                    scale: 1.02
                });
            }

            // Add glow effect to active elements
            setInterval(() => {
                const onlineDots = document.querySelectorAll('.status-dot.online');
                onlineDots.forEach(dot => {
                    dot.style.boxShadow = '0 0 20px var(--success)';
                    setTimeout(() => {
                        dot.style.boxShadow = '0 0 10px var(--success)';
                    }, 500);
                });
            }, 2000);
        });

        // Add ripple effect to buttons
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('btn')) {
                const ripple = document.createElement('span');
                ripple.style.position = 'absolute';
                ripple.style.borderRadius = '50%';
                ripple.style.background = 'rgba(255, 255, 255, 0.5)';
                ripple.style.width = ripple.style.height = '100px';
                ripple.style.left = e.offsetX - 50 + 'px';
                ripple.style.top = e.offsetY - 50 + 'px';
                ripple.style.animation = 'ripple 0.6s ease-out';

                e.target.appendChild(ripple);
                setTimeout(() => ripple.remove(), 600);
            }
        });

        // ===== EXPOSE FUNCTIONS TO WINDOW FOR HTML ACCESS =====
        window.toggleSidebar = toggleSidebar;
        window.startValidation = startValidation;
        window.exportFilteredResults = exportFilteredResults;
        window.createAndLaunchCampaign = createAndLaunchCampaign;
        window.saveAsDraft = saveAsDraft;
        window.extractContacts = extractContacts;
        window.addToBlacklist = addToBlacklist;
        window.removeFromBlacklist = removeFromBlacklist;
        window.renderBlacklist = renderBlacklist;
        window.pauseCampaignById = pauseCampaignById;
        window.resumeCampaignById = resumeCampaignById;
        window.startCampaignById = startCampaignById;
        window.stopCampaignById = stopCampaignById;
        window.deleteCampaignById = deleteCampaignById;
        window.startAgent = startAgent;
        window.stopAgent = stopAgent;
        window.restartAgent = restartAgent;
        window.addProduct = addProduct;
        window.refreshDeals = refreshDeals;
        window.exportDeals = exportDeals;
        window.viewDealDetails = viewDealDetails;
        window.toggleDND = toggleDND;
        window.clearGroupMemory = clearGroupMemory;
        window.exportToCSV = exportToCSV;
        window.exportToExcel = exportToExcel;
        window.renderCampaigns = renderCampaigns;

        })(); // End of IIFE
    </script>
</body>
</html>
