    <script>
        (function() {
            console.log('=== Dashboard Main Script Starting ===');

            // ===== SUPABASE AUTHENTICATION =====
            const supabase = window.supabase.createClient(
                'https://xrphyjkrzolqyowkkvzf.supabase.co',
                'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhycGh5amtyem9scXlvd2trdnpmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc5NjM5NTIsImV4cCI6MjA5MzUzOTk1Mn0.Tk-ESBR82crBvISHFJAP2JE_zmkUc4YRgB7VgQtRBFE',
                {
                    auth: {
                        persistSession: true,
                        detectSessionInUrl: true,
                        autoRefreshToken: true,
                        storage: window.localStorage
                    }
                }
            );

            console.log('✓ Supabase client initialized with session persistence');

            // ===== WHATSAPP CONNECTION MANAGEMENT =====
            let socket = null;
            let whatsappConnected = false;

            // Initialize Socket.IO connection
            function initializeSocketIO() {
                console.log('🔌 Initializing Socket.IO connection...');

                socket = io('http://localhost:3000', {
                    transports: ['websocket', 'polling']
                });

                socket.on('connect', () => {
                    console.log('✓ Socket.IO connected');
                });

                socket.on('disconnect', () => {
                    console.log('🔌 Socket.IO disconnected');
                });

                // WhatsApp Status Event
                socket.on('whatsapp:status', (data) => {
                    console.log('📱 WhatsApp status:', data);
                    updateWhatsAppStatus(data.connected, data.info);
                });

                // QR Code Event
                socket.on('whatsapp:qr', (data) => {
                    console.log('📱 QR Code received');
                    showQRCode(data.qr);
                });

                // Ready Event
                socket.on('whatsapp:ready', (data) => {
                    console.log('✅ WhatsApp ready:', data);
                    showConnectedState(data.info);
                    updateWhatsAppStatus(true, data.info);
                });

                // Authenticated Event
                socket.on('whatsapp:authenticated', (data) => {
                    console.log('🔐 WhatsApp authenticated');
                    showLoadingState('Authenticated! Loading WhatsApp...');
                });

                // Auth Failure Event
                socket.on('whatsapp:auth_failure', (data) => {
                    console.error('❌ Authentication failed:', data);
                    showErrorState('Authentication failed: ' + data.error);
                });

                // Disconnected Event
                socket.on('whatsapp:disconnected', (data) => {
                    console.log('🔌 WhatsApp disconnected:', data.reason);
                    updateWhatsAppStatus(false, null);
                    showLoadingState('Reconnecting...');
                });

                // Loading Event
                socket.on('whatsapp:loading', (data) => {
                    console.log(`⏳ Loading: ${data.percent}%`);
                    showLoadingState(data.message, data.percent);
                });

                // Logged Out Event
                socket.on('whatsapp:logged_out', (data) => {
                    console.log('👋 Logged out');
                    updateWhatsAppStatus(false, null);
                    showLoadingState('Generating new QR code...');
                });

                // Error Event
                socket.on('whatsapp:error', (data) => {
                    console.error('❌ WhatsApp error:', data);
                    showErrorState(data.error);
                });

                // ===== REAL-TIME MESSAGE EVENTS =====
                socket.on('message:received', (data) => {
                    console.log('📨 Message received:', data);
                    addMessageToFeed(data, 'incoming');
                    updateStats();
                });

                socket.on('message:sent', (data) => {
                    console.log('📤 Message sent:', data);
                    addMessageToFeed(data, 'outgoing');
                    updateStats();
                });

                // ===== STATISTICS UPDATE =====
                socket.on('stats:update', (data) => {
                    console.log('📊 Stats updated:', data);
                    updateDashboardStats(data);
                });

                // ===== DEALS TRACKING =====
                socket.on('deal:new', (data) => {
                    console.log('💰 New deal:', data);
                    addDealToTracker(data);
                    showNotification('New deal detected!', 'success');
                });

                // ===== AI AGENT STATUS =====
                socket.on('ai-agent:status', (data) => {
                    console.log('🤖 AI Agent status:', data.enabled);
                    updateAIAgentStatus(data.enabled);
                });

                // ===== BULK SEND EVENTS =====
                socket.on('bulk-send:progress', (data) => {
                    console.log('📤 Bulk send progress:', data);
                    updateBulkSendProgress(data);
                });

                socket.on('bulk-send:complete', (data) => {
                    console.log('✅ Bulk send complete:', data);
                    showNotification(`Bulk send complete: ${data.sent} sent, ${data.failed} failed`, 'success');
                });
            }

            // Update WhatsApp status in sidebar
            function updateWhatsAppStatus(connected, info) {
                whatsappConnected = connected;

                const statusEl = document.getElementById('whatsapp-status');
                const statusBadge = document.getElementById('connection-status-badge');
                const profileEl = document.getElementById('whatsapp-profile');

                if (!statusEl || !statusBadge) return;

                if (connected && info) {
                    console.log('📱 Updating sidebar with connection info:', info);

                    // Connected state
                    statusEl.className = 'whatsapp-status connected';
                    statusBadge.className = 'status-badge connected';
                    statusBadge.innerHTML = '<i class="fas fa-circle"></i><span>Connected</span>';

                    // Show profile info
                    if (profileEl) {
                        profileEl.style.display = 'flex';
                        const profilePic = document.getElementById('profile-pic');
                        const profileName = document.getElementById('profile-name');
                        const profileNumber = document.getElementById('profile-number');

                        // Update profile picture with fallback
                        if (profilePic) {
                            if (info.profilePicUrl) {
                                console.log('✓ Setting profile picture from URL');
                                profilePic.src = info.profilePicUrl;
                                profilePic.style.display = 'block';

                                // Handle image load error
                                profilePic.onerror = function() {
                                    console.log('⚠️ Profile picture failed to load, using default avatar');
                                    this.style.display = 'none';
                                    // Create default avatar if not exists
                                    let defaultAvatar = profileEl.querySelector('.default-avatar');
                                    if (!defaultAvatar) {
                                        defaultAvatar = document.createElement('div');
                                        defaultAvatar.className = 'default-avatar';
                                        defaultAvatar.innerHTML = '<i class="fas fa-user"></i>';
                                        defaultAvatar.style.cssText = 'width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--primary), var(--secondary)); display: flex; align-items: center; justify-content: center; font-size: 20px; color: white;';
                                        profilePic.parentNode.insertBefore(defaultAvatar, profilePic);
                                    }
                                };

                                // Handle successful load
                                profilePic.onload = function() {
                                    console.log('✓ Profile picture loaded successfully');
                                    // Remove default avatar if exists
                                    const defaultAvatar = profileEl.querySelector('.default-avatar');
                                    if (defaultAvatar) {
                                        defaultAvatar.remove();
                                    }
                                };
                            } else {
                                console.log('⚠️ No profile picture URL provided, using default avatar');
                                profilePic.style.display = 'none';

                                // Create default avatar
                                let defaultAvatar = profileEl.querySelector('.default-avatar');
                                if (!defaultAvatar) {
                                    defaultAvatar = document.createElement('div');
                                    defaultAvatar.className = 'default-avatar';
                                    defaultAvatar.innerHTML = '<i class="fas fa-user"></i>';
                                    defaultAvatar.style.cssText = 'width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--primary), var(--secondary)); display: flex; align-items: center; justify-content: center; font-size: 20px; color: white; border: 2px solid var(--primary);';
                                    profilePic.parentNode.insertBefore(defaultAvatar, profilePic);
                                }
                            }
                        }

                        // Update name and number
                        if (profileName) {
                            profileName.textContent = info.name || 'Unknown';
                        }
                        if (profileNumber) {
                            profileNumber.textContent = '+' + info.number;
                        }
                    }
                } else {
                    // Disconnected state
                    console.log('📱 Updating sidebar to disconnected state');
                    statusEl.className = 'whatsapp-status disconnected';
                    statusBadge.className = 'status-badge disconnected';
                    statusBadge.innerHTML = '<i class="fas fa-circle"></i><span>Disconnected</span>';

                    if (profileEl) {
                        profileEl.style.display = 'none';
                        // Remove default avatar if exists
                        const defaultAvatar = profileEl.querySelector('.default-avatar');
                        if (defaultAvatar) {
                            defaultAvatar.remove();
                        }
                    }
                }
            }

            // Show QR Code
            function showQRCode(qrDataUrl) {
                hideAllConnectionStates();

                const qrContainer = document.getElementById('qr-code-container');
                const qrImage = document.getElementById('qr-code-image');
                const statusBadge = document.getElementById('connection-status-badge');

                if (qrContainer) qrContainer.style.display = 'flex';
                if (qrImage) qrImage.src = qrDataUrl;
                if (statusBadge) {
                    statusBadge.className = 'status-badge connecting';
                    statusBadge.innerHTML = '<i class="fas fa-circle"></i><span>Waiting for Scan</span>';
                }
            }

            // Show Loading State
            function showLoadingState(message, percent) {
                hideAllConnectionStates();

                const loadingState = document.getElementById('loading-state');
                const loadingMessage = document.getElementById('loading-message');
                const loadingProgress = document.getElementById('loading-progress');
                const progressFill = document.getElementById('progress-fill');
                const progressText = document.getElementById('progress-text');
                const statusBadge = document.getElementById('connection-status-badge');

                if (loadingState) loadingState.style.display = 'flex';
                if (loadingMessage) loadingMessage.textContent = message || 'Loading...';

                if (percent !== undefined && loadingProgress && progressFill && progressText) {
                    loadingProgress.style.display = 'block';
                    progressFill.style.width = percent + '%';
                    progressText.textContent = Math.round(percent) + '%';
                } else if (loadingProgress) {
                    loadingProgress.style.display = 'none';
                }

                if (statusBadge) {
                    statusBadge.className = 'status-badge connecting';
                    statusBadge.innerHTML = '<i class="fas fa-circle"></i><span>Connecting</span>';
                }
            }

            // Show Connected State
            function showConnectedState(info) {
                hideAllConnectionStates();

                const connectedState = document.getElementById('connected-state');
                const connectedProfilePic = document.getElementById('connected-profile-pic');
                const connectedName = document.getElementById('connected-name');
                const connectedNumber = document.getElementById('connected-number');

                if (connectedState) connectedState.style.display = 'flex';

