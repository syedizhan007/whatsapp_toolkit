        // Export Deals
        function exportDeals() {
            // Get deals data
            const deals = [
                ['Customer', 'Phone', 'Message', 'Date', 'Status'],
                ['John Doe', '+1234567890', 'Interested in bulk order', '2026-04-28', 'Pending'],
                ['Jane Smith', '+0987654321', 'Ready to purchase', '2026-04-27', 'Completed']
            ];

            // Convert to CSV
            const csv = deals.map(row => row.join(',')).join('\n');

            // Download
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'deals_export_' + new Date().toISOString().split('T')[0] + '.csv';
            a.click();
            window.URL.revokeObjectURL(url);
        }

        // ===== STATISTICS FUNCTIONS =====
        function updateDashboardStats(stats) {
            // Update stat cards
            const statCards = document.querySelectorAll('.stat-card .stat-value');
            if (statCards.length >= 4) {
                statCards[0].textContent = stats.totalMessages || 0;
                statCards[1].textContent = stats.messagesReceived || 0;
                statCards[2].textContent = stats.messagesSent || 0;
                statCards[3].textContent = stats.dealsLocked || 0;
            }
        }

        async function fetchStats() {
            try {
                const response = await fetch('/api/stats');
                const stats = await response.json();
                updateDashboardStats(stats);
            } catch (error) {
                console.error('Failed to fetch stats:', error);
            }
        }

        // View Deal Details
        function viewDealDetails(phone) {
            alert(`Viewing details for ${phone}\n\nThis would open a detailed view of the deal.`);
        }

        // ===== DND TOGGLE FUNCTION =====
        let dndEnabled = true; // Default: DND ON

        function toggleDND() {
            dndEnabled = !dndEnabled;

            const badge = document.getElementById('dndBadge');
            const statusDot = document.getElementById('dndStatusDot');
            const statusText = document.getElementById('dndStatusText');
            const timeInfo = document.getElementById('dndTimeInfo');
            const toggleIcon = document.getElementById('dndToggleIcon');

            if (dndEnabled) {
                // DND ON
                badge.className = 'dnd-badge active';
                statusDot.className = 'status-dot online';
                statusText.textContent = 'DND: ON';
                timeInfo.textContent = 'No messages 11PM-8AM';
                toggleIcon.className = 'fas fa-toggle-on';
                showNotification('DND Mode: ON - Messages will not be sent between 11PM-8AM', 'success');
            } else {
                // DND OFF
                badge.className = 'dnd-badge';
                statusDot.className = 'status-dot offline';
                statusText.textContent = 'DND: OFF';
                timeInfo.textContent = 'Sending anytime';
                toggleIcon.className = 'fas fa-toggle-off';
                showNotification('DND Mode: OFF - Messages will be sent anytime', 'info');
            }

            console.log(`DND Mode: ${dndEnabled ? 'ON' : 'OFF'}`);
        }

        // Show notification
        function showNotification(message, type) {
            console.log(`[${type.toUpperCase()}] ${message}`);
            // Simple alert for now - can be enhanced with toast notifications
            alert(message);
        }

        // ===== BLACKLIST MANAGER FUNCTIONS - BUG FIX 3 =====
        function addToBlacklist() {
            const input = document.getElementById('blacklistInput');
            const number = input.value.trim();

            if (!number) {
                alert('Please enter a phone number');
                return;
            }

            // Check if already in blacklist
            if (blacklist.includes(number)) {
                alert('This number is already in the blacklist');
                return;
            }

            // Add to blacklist
            blacklist.push(number);
            input.value = '';

            // Re-render blacklist
            renderBlacklist();

            showNotification(`Added ${number} to blacklist`, 'success');
        }

        function removeFromBlacklist(number) {
            const index = blacklist.indexOf(number);
            if (index > -1) {
                blacklist.splice(index, 1);
                renderBlacklist();
                showNotification(`Removed ${number} from blacklist`, 'success');
            }
        }

        function renderBlacklist() {
            const container = document.getElementById('blacklistContainer');

            if (blacklist.length === 0) {
                container.innerHTML = `
                    <div style="text-align: center; padding: 20px; color: var(--text-secondary);">
                        <i class="fas fa-inbox" style="font-size: 32px; opacity: 0.3; display: block; margin-bottom: 8px;"></i>
                        No numbers in blacklist
                    </div>
                `;
                return;
            }

            container.innerHTML = blacklist.map(number => `
                <div class="list-item">
                    <span>${number}</span>
                    <button class="btn btn-danger" style="padding: 4px 8px; font-size: 11px;" onclick="removeFromBlacklist('${number}')">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            `).join('');
        }

        // Add Product
        function addProduct() {
            const name = document.getElementById('productName').value;
            const price = document.getElementById('productPrice').value;

            if (!name || !price) {
                alert('Please enter both product name and price');
                return;
            }

            const productsList = document.getElementById('productsList');
            const newProduct = document.createElement('div');
            newProduct.className = 'list-item';
            newProduct.innerHTML = `
                <div>
                    <strong>${name}</strong>
                    <div style="font-size: 12px; color: var(--text-secondary);">Rs. ${price}</div>
                </div>
                <button class="btn btn-danger" style="padding: 4px 8px; font-size: 11px;" onclick="this.parentElement.remove()">
                    <i class="fas fa-trash"></i>
                </button>
            `;
            productsList.insertBefore(newProduct, productsList.firstChild);

            // Clear inputs
            document.getElementById('productName').value = '';
            document.getElementById('productPrice').value = '';

            // Animate
            newProduct.style.animation = 'slideIn 0.3s ease';
        }

        // ===== REAL MESSAGE FEED FUNCTIONS =====
        function addMessageToFeed(data, type) {
            const terminal = document.getElementById('liveMessages');
            if (!terminal) return;

            const time = new Date(data.timestamp).toLocaleTimeString('en-US', { hour12: false });
            const line = document.createElement('div');
            line.className = 'terminal-line';

            let content = '';
            if (type === 'incoming') {
                const phone = data.from.replace('@c.us', '');
                content = `<span class="terminal-time">[${time}]</span><span class="terminal-incoming">← ${phone}: ${data.body}</span>`;
            } else if (type === 'outgoing') {
                const phone = data.to ? data.to.replace('@c.us', '') : 'You';
                content = `<span class="terminal-time">[${time}]</span><span class="terminal-outgoing">→ You: ${data.body}</span>`;
            }

            line.innerHTML = content;
            terminal.appendChild(line);
            terminal.scrollTop = terminal.scrollHeight;

            // Keep only last 50 messages in DOM
            const lines = terminal.querySelectorAll('.terminal-line');
            if (lines.length > 50) {
                lines[0].remove();
            }
        }

        async function loadMessageHistory() {
            try {
                const response = await fetch('/api/messages');
                const data = await response.json();

                const terminal = document.getElementById('liveMessages');
                if (!terminal) return;

                terminal.innerHTML = '';

                if (data.messages && data.messages.length > 0) {
                    // Show last 20 messages
                    const recentMessages = data.messages.slice(0, 20).reverse();
                    recentMessages.forEach(msg => {
                        const type = msg.type === 'received' ? 'incoming' : 'outgoing';
                        addMessageToFeed(msg, type);
                    });
                } else {
                    terminal.innerHTML = `
                        <div style="text-align: center; padding: 40px; color: var(--text-secondary);">
                            <i class="fas fa-comments" style="font-size: 48px; opacity: 0.3; margin-bottom: 16px;"></i>
                            <div>No messages yet</div>
                            <div style="font-size: 12px; margin-top: 8px;">Messages will appear here when you start chatting</div>
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Failed to load message history:', error);
            }
        }

