# WhatsApp Toolkit Environment Configuration

# ===== SUPABASE CONFIGURATION (REQUIRED) =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ===== GROQ API CONFIGURATION (FOR AI AGENT) =====
GROQ_API_KEY=your_groq_api_key_here

# ===== SERVER CONFIGURATION =====
PORT=3000
NODE_ENV=development

# ===== WHATSAPP CONFIGURATION =====
HEADLESS=true

# ===== SECURITY CONFIGURATION =====
# Rate Limiting (requests per minute)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=5

# Session Secret (IMPORTANT: Generate a random string for production)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-random-string-in-production

# ===== DEBUG MODE =====
DEBUG=false
