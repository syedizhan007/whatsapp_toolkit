# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# JWT Authentication
JWT_SECRET=change-this-to-a-random-secret-key
JWT_EXPIRES_IN=7d

# Groq AI Configuration
GROQ_API_KEY=your-groq-api-key-here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile

# Database Paths
CAMPAIGNS_DB_PATH=./bulk-sender/campaigns.db
DEALS_JSON_PATH=./whatsapp-mcp/deals.json

# WhatsApp Session Paths
VALIDATOR_SESSION_PATH=./.wwebjs_auth_validator
BULK_SENDER_SESSION_PATH=./.wwebjs_auth_bulk
AI_AGENT_SESSION_PATH=./.wwebjs_auth_agent

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
